    {
      "name": "Happy Path",
      "item": [
        {
          "name": "GET Users - Page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "\tpm.response.to.have.status(200);",
                  "} ",
                  ")",
                  "pm.test(\"Page number is 1\", () =>{",
                  "\tconst jsonData = pm.response.json();",
                  "\tpm.expect(jsonData.page).to.equal(1);",
                  "})",
                  "pm.test(\"Data array is not empty\", () => {",
                  "\tconst jsonData = pm.response.json();",
                  "\tpm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "})",
                  "pm.test(\"Data is an array\", () => {",
                  "\tconst jsonData = pm.response.json();",
                  "\tpm.expect(jsonData.data).to.be.an(\"array\");",
                  "})",
                  "pm.test(\"Returned records match per page count\", ()=> {",
                  "\tconst jsonData = pm.response.json();",
                  "\tpm.expect(jsonData.data.length).to.equal(jsonData.per_page);",
                  "})",
                  "pm.test(\"Each user has required fields\", () =>{",
                  "\tconst data = pm.response.json().data;",
                  "\tdata.forEach(user =>{",
                  "\t\tpm.expect(user).to.have.property(\"id\");",
                  "\t\tpm.expect(user).to.have.property(\"email\");",
                  "\t\tpm.expect(user).to.have.property(\"first_name\");",
                  "\t\tpm.expect(user).to.have.property(\"last_name\");",
                  "\t\tpm.expect(user).to.have.property(\"avatar\");",
                  "\t})",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users?page=1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
