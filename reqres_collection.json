                  "pm.test(\"Status code is 200\", () => {",
                  "\tpm.response.to.have.status(200);",
                  "})",
                  "pm.test(\"Response has token\", () => {",
                  "\tpm.expect(jsonData).to.have.property(\"token\");",
                  "\tpm.expect(jsonData.token).to.be.not.empty;",
                  "\tpm.environment.set(\"token\", jsonData.token);",
                  "})",
                  "pm.test(\"Response time is under 500ms\", () => {",
